# Required for the Enterprise image. Obtain a key or trial from Ant Media.
ANT_MEDIA_LICENSE_KEY=replace-with-your-ant-media-license-key

# The current latest Enterprise image is linux/amd64. Keep this value on an
# Apple Silicon Mac unless you deliberately use Ant Media's older `arm` tag.
ANT_MEDIA_IMAGE=antmedia/enterprise:latest
ANT_MEDIA_PLATFORM=linux/amd64

# IP of this Mac on the local network. Install Caddy's root certificate on
# phones/cameras that open the POC through this address.
POC_D1_LAN_IP=192.168.0.188

# Advertised in Ant Media ICE candidates instead of the Docker private IP.
ANT_MEDIA_SERVER_NAME=192.168.0.188

# Same-machine default:
ANT_MEDIA_WEBSOCKET_URL=wss://localhost:3543/live/websocket

# For phones/cameras on the LAN, replace the line above with the same LAN IP:
# ANT_MEDIA_WEBSOCKET_URL=wss://192.168.0.188:3543/live/websocket

ANT_MEDIA_PROGRAM_STREAM_ID=sell-image
